WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://127.0.0.1:8001/auth/callback
WHOOP_API_BASE_URL=https://api.prod.whoop.com/developer
WHOOP_OAUTH_AUTHORIZE_URL=https://api.prod.whoop.com/oauth/oauth2/auth
WHOOP_OAUTH_TOKEN_URL=https://api.prod.whoop.com/oauth/oauth2/token
CACHE_DIR=/cache
SECRETS_DIR=/secrets
TOKEN_FILE_NAME=whoop_tokens.json
WHOOP_TIMEOUT_SECONDS=10
HEALTH_TIMEOUT_SECONDS=3
WHOOP_MIN_INTERVAL_SECONDS=300
CACHE_RETENTION_DAYS=30
WHOOP_HTTP_LOG_ENABLED=true
WHOOP_HTTP_LOG_LEVEL=INFO
WHOOP_HTTP_LOG_BODY_MAX_CHARS=4000
WHOOP_HTTP_LOG_REDACT_SENSITIVE=true
WHOOP_HTTP_LOG_FILE_DIR=/tmp
TZ=Europe/Moscow
